{
  "name": "@cleanslice/paddock",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "eval": "bun run src/cli.ts run",
    "eval:quick": "bun run src/cli.ts run --count 3 --no-improve",
    "eval:full": "bun run src/cli.ts run --count 10",
    "eval:no-improve": "bun run src/cli.ts run --no-improve",
    "eval:category": "bun run src/cli.ts run --categories",
    "scenarios": "bun run src/cli.ts scenarios",
    "mcp": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.2"
  }
}
